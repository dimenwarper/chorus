# Chorus environment variables
# Copy to /etc/chorus/env and fill in values

# Required
DATABASE_PATH=/var/lib/chorus/chorus.db
SECRET_KEY_BASE=generate-with-mix-phx-gen-secret
PHX_HOST=your-domain.com
PHX_SERVER=true
PORT=4000

# GitHub OAuth
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# Admin — numeric GitHub user ID (find via: curl https://api.github.com/users/USERNAME)
ADMIN_GITHUB_ID=

# GitHub repo creation (optional — needs personal access token with repo scope)
GITHUB_TOKEN=
GITHUB_OWNER=
